{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://atlasui.vercel.app/schema.json",
  "title": "AtlasUI Config",
  "description": "Configuration file for AtlasUI CLI",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "style": {
      "type": "string",
      "enum": ["default", "minimal"],
      "default": "default",
      "description": "Visual style preset"
    },
    "typescript": {
      "type": "boolean",
      "default": true,
      "description": "Use TypeScript for generated files"
    },
    "tailwind": {
      "type": "object",
      "properties": {
        "config": {
          "type": "string",
          "description": "Path to tailwind.config.ts",
          "default": "tailwind.config.ts"
        },
        "css": {
          "type": "string",
          "description": "Path to your global CSS file",
          "default": "app/globals.css"
        },
        "baseColor": {
          "type": "string",
          "enum": ["slate", "gray", "zinc", "neutral", "stone"],
          "default": "slate",
          "description": "Base neutral color palette"
        },
        "cssVariables": {
          "type": "boolean",
          "default": true,
          "description": "Use CSS custom properties for theming"
        }
      },
      "required": ["config", "css"]
    },
    "aliases": {
      "type": "object",
      "properties": {
        "components": {
          "type": "string",
          "description": "Import alias for components directory",
          "default": "@/components/ui"
        },
        "utils": {
          "type": "string",
          "description": "Import alias for utils",
          "default": "@/lib/utils"
        },
        "hooks": {
          "type": "string",
          "description": "Import alias for hooks",
          "default": "@/hooks"
        }
      }
    }
  },
  "required": ["tailwind", "aliases"]
}
